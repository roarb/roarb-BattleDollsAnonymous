{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "targetFaction": {
          "type": "string",
          "description": "The user's selected target faction for combat readiness."
        },
        "targetArmyId": {
          "type": "string",
          "description": "The user's selected target army ID for combat readiness."
        },
        "unlockedAchievements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of unlocked achievement IDs."
        },
        "currentStreak": {
          "type": "number",
          "description": "The user's current consecutive days of hobby progress."
        },
        "bestStreak": {
          "type": "number",
          "description": "The user's longest consecutive days of hobby progress."
        },
        "lastStreakDate": {
          "type": "string",
          "description": "The YYYY-MM-DD date of the last streak increment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "CommunityProfile": {
      "title": "Community Profile",
      "description": "Public and relationship-visible profile data safe to expose to other members.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "displayNameLower": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "allowFriendRequests": { "type": "boolean" },
        "allowSponsorRequests": { "type": "boolean" },
        "shareRelapses": { "type": "boolean" },
        "shareProgress": { "type": "boolean" },
        "currentStreak": { "type": "number" },
        "badgeCount": { "type": "number" },
        "progressSummary": {
          "type": "object",
          "properties": {
            "unbuilt": { "type": "number" },
            "assembled": { "type": "number" },
            "primed": { "type": "number" },
            "basicPaint": { "type": "number" },
            "completed": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "displayNameLower", "isPublic", "allowFriendRequests", "allowSponsorRequests", "shareRelapses", "shareProgress"]
    },
    "MiniatureModel": {
      "title": "Miniature Model",
      "description": "A model or unit in the user's collection.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "modelName": {
          "type": "string",
          "description": "The name of the model or unit."
        },
        "nickname": {
          "type": "string",
          "description": "An optional nickname or distinguishing description for the unit."
        },
        "qty": {
          "type": "number",
          "description": "The quantity of this model."
        },
        "status": {
          "type": "string",
          "enum": ["Unbuilt", "Assembled", "Primed", "Basic Paint", "Completed"],
          "description": "The current hobby status of the model."
        },
        "pointsPerModel": {
          "type": "number",
          "description": "The points value per model (optional)."
        },
        "unitCost": {
          "type": "number",
          "description": "The MSRP or cost of the unit/box (optional)."
        },
        "faction": {
          "type": "string",
          "description": "The faction or army this model belongs to."
        },
        "gameSystem": {
          "type": "string",
          "description": "The game system this model belongs to."
        },
        "images": {
          "type": "object",
          "description": "Optional progress image URLs keyed by hobby status."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "modelName", "qty", "status", "faction", "createdAt", "updatedAt"]
    },
    "HobbyProject": {
      "title": "Hobby Project",
      "description": "A goal or project the user is working towards.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "The target completion date."
        },
        "targetPoints": {
          "type": "number",
          "description": "The target points value for the project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "title", "createdAt", "updatedAt"]
    },
    "ArmyList": {
      "title": "Army List",
      "description": "A saved army list generated by AI or the user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "title": {
          "type": "string",
          "description": "The title of the army list."
        },
        "pointsLimit": {
          "type": "number",
          "description": "The points limit for the list."
        },
        "faction": {
          "type": "string",
          "description": "The faction for the list."
        },
        "content": {
          "type": "string",
          "description": "The content of the army list (markdown or text)."
        },
        "notes": {
          "type": "string",
          "description": "User notes for the army list."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "title", "pointsLimit", "faction", "content", "createdAt", "updatedAt"]
    },
    "GameRecord": {
      "title": "Game Record",
      "description": "A tracked game/match result.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "armyListId": {
          "type": "string",
          "description": "The ID of the army list used in this game."
        },
        "outcome": {
          "type": "string",
          "enum": ["Win", "Loss", "Draw"],
          "description": "The outcome of the match."
        },
        "pointsFor": {
          "type": "number",
          "description": "Control points scored by the user."
        },
        "pointsAgainst": {
          "type": "number",
          "description": "Control points scored by the opponent."
        },
        "opponentName": {
          "type": "string",
          "description": "Name of the opponent."
        },
        "opponentFaction": {
          "type": "string",
          "description": "Faction used by the opponent."
        },
        "mission": {
          "type": "string",
          "description": "Mission or scenario played."
        },
        "notes": {
          "type": "string",
          "description": "Game summary and notes."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "outcome", "createdAt", "updatedAt"]
    },
    "RelapseRecord": {
      "title": "Relapse Record",
      "description": "Tracks purchases and spending on new boxes.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "msrp": { "type": "number", "description": "Money spent" },
        "boxName": { "type": "string", "description": "The item bought" },
        "reason": { "type": "string", "description": "Reason for lapse" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "msrp", "boxName", "reason", "createdAt", "updatedAt"]
    },
    "ConnectionRequest": {
      "title": "Connection Request",
      "description": "A pending, accepted, or declined friend/sponsor request.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "kind": { "type": "string", "enum": ["friend", "sponsor"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "kind", "status"]
    },
    "Relationship": {
      "title": "Relationship",
      "description": "Accepted friend or sponsorship relationship used for access checks.",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "kind": { "type": "string", "enum": ["friend", "sponsorship"] },
        "status": { "type": "string", "enum": ["active"] },
        "memberUids": { "type": "array", "items": { "type": "string" } },
        "requesterUid": { "type": "string" },
        "recipientUid": { "type": "string" },
        "sponsorUid": { "type": "string" },
        "sponseeUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "kind", "status", "memberUids", "requesterUid", "recipientUid"]
    },
    "ActivityRecord": {
      "title": "Activity Record",
      "description": "Shareable community feed event for relapses, progress, and milestones.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "type": { "type": "string", "enum": ["relapse", "progress", "milestone"] },
        "visibility": { "type": "string", "enum": ["public", "connections"] },
        "details": { "type": "object" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userDisplayName", "type", "visibility", "details", "likes", "commentCount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "Stores private user account data."
    },
    "/profiles/{userId}": {
      "schema": { "$ref": "CommunityProfile" },
      "description": "Stores public and community-visible member profiles."
    },
    "/collection/{modelId}": {
      "schema": { "$ref": "MiniatureModel" },
      "description": "Stores miniature models in a user's collection."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "HobbyProject" },
      "description": "Stores hobby projects."
    },
    "/armyLists/{listId}": {
      "schema": { "$ref": "ArmyList" },
      "description": "Stores saved army lists."
    },
    "/gameLogs/{logId}": {
      "schema": { "$ref": "GameRecord" },
      "description": "Stores game logs and match results."
    },
    "/relapses/{relapseId}": {
      "schema": { "$ref": "RelapseRecord" },
      "description": "Stores relapse records (purchases)."
    },
    "/connectionRequests/{requestId}": {
      "schema": { "$ref": "ConnectionRequest" },
      "description": "Stores friend and sponsorship requests."
    },
    "/relationships/{relationshipId}": {
      "schema": { "$ref": "Relationship" },
      "description": "Stores accepted friend and sponsorship relationships."
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "ActivityRecord" },
      "description": "Stores shareable community activity feed events."
    }
  }
}
