{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "MiniatureModel": {
      "title": "Miniature Model",
      "description": "A model or unit in the user's collection.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "modelName": {
          "type": "string",
          "description": "The name of the model or unit."
        },
        "qty": {
          "type": "number",
          "description": "The quantity of this model."
        },
        "status": {
          "type": "string",
          "enum": ["Unbuilt", "Assembled", "Primed", "Painted", "Tabletop Ready"],
          "description": "The current hobby status of the model."
        },
        "pointsPerModel": {
          "type": "number",
          "description": "The points value per model (optional)."
        },
        "faction": {
          "type": "string",
          "description": "The faction or army this model belongs to."
        },
        "gameSystem": {
          "type": "string",
          "description": "The game system this model belongs to."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "modelName", "qty", "status", "faction", "createdAt", "updatedAt"]
    },
    "HobbyProject": {
      "title": "Hobby Project",
      "description": "A goal or project the user is working towards.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "The target completion date."
        },
        "targetPoints": {
          "type": "number",
          "description": "The target points value for the project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "title", "createdAt", "updatedAt"]
    },
    "ArmyList": {
      "title": "Army List",
      "description": "A saved army list generated by AI or the user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "title": {
          "type": "string",
          "description": "The title of the army list."
        },
        "pointsLimit": {
          "type": "number",
          "description": "The points limit for the list."
        },
        "faction": {
          "type": "string",
          "description": "The faction for the list."
        },
        "unitsJson": {
          "type": "string",
          "description": "A JSON string representing the units in the list."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "title", "pointsLimit", "faction", "unitsJson", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "Stores user profiles."
    },
    "/collection/{modelId}": {
      "schema": { "$ref": "MiniatureModel" },
      "description": "Stores miniature models in a user's collection."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "HobbyProject" },
      "description": "Stores hobby projects."
    },
    "/armyLists/{listId}": {
      "schema": { "$ref": "ArmyList" },
      "description": "Stores saved army lists."
    }
  }
}
